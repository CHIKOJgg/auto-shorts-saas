{
  "name": "auto-short-saas",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:dev:stop": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "docker compose up -d",
    "docker:prod:logs": "docker compose logs -f",
    "docker:prod:stop": "docker compose down",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm start --prefix frontend/frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --prefix frontend/frontend",
    "start:backend": "npm start --prefix backend",
    "install:all": "npm install --prefix backend && npm install --prefix frontend/frontend",
    "lint:backend": "npm run lint --prefix backend",
    "test:backend": "npm test --prefix backend",
    "test:frontend": "npm test --prefix frontend/frontend",
    "test": "npm run test:backend && npm run test:frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "knex": "^3.3.0",
    "pg": "^8.22.0"
  }
}
