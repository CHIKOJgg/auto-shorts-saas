PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-3.5-turbo

# CORS
CORS_ORIGIN=http://localhost:3000

# Database (inside Docker network, use service name as host)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auto_shorts_saas

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (leave empty if not using payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
